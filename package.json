{
  "name": "restful-booker-platform-automation",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio QA automation framework for Restful Booker Platform using Playwright",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:api": "playwright test tests/api",
    "test:e2e": "playwright test tests/ui",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "dotenv": "^17.4.1",
    "typescript": "^5.9.3"
  }
}
